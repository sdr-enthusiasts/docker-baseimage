{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    "default:pinDigestsDisabled"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* 0 1 * *"]
  },
  "timezone": "Etc/UTC",
  "schedule": ["* 0 1 * *"],
  "enabledManagers": ["nix", "github-actions", "dockerfile", "custom.regex"],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "prCreation": "immediate",
  "automerge": true,
  "platformAutomerge": true,
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "schedule": ["at any time"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["debian"],
      "versioning": "regex:^(?<compatibility>\\w+)-(?<major>\\d{4})(?<minor>\\d{2})(?<patch>\\d{2})-slim$"
    },
    {
      "matchManagers": ["github-actions", "nix"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin"],
      "automerge": true
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/^ghcr\\.io/sdr-enthusiasts/.*$/"],
      "enabled": false
    },
    {
      "matchDepNames": ["just-containers/s6-overlay"],
      "versioning": "loose",
      "schedule": ["at any time"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump S6OVERLAY_VERSION in Dockerfile.base against just-containers/s6-overlay GitHub releases",
      "managerFilePatterns": ["/^Dockerfile\\.base$/"],
      "matchStrings": ["S6OVERLAY_VERSION=\"(?<currentValue>v[\\d.]+)\""],
      "depNameTemplate": "just-containers/s6-overlay",
      "datasourceTemplate": "github-releases"
    }
  ]
}
